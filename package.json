{
  "name": "@octohash/vite-config",
  "type": "module",
  "version": "0.5.1",
  "packageManager": "pnpm@11.9.0",
  "description": "Opinionated Vite config preset.",
  "author": "jinghaihan",
  "license": "MIT",
  "homepage": "https://github.com/jinghaihan/vite-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/vite-config.git"
  },
  "bugs": {
    "url": "https://github.com/jinghaihan/vite-config/issues"
  },
  "keywords": [
    "vite",
    "vite-config"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "deps": "taze major -I",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "release": "bumpp",
    "prepare": "simple-git-hooks",
    "bootstrap": "pnpm install",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@intlify/unplugin-vue-i18n": ">=11.0.0",
    "@unhead/vue": ">=2.0.0",
    "unocss": ">=66.0.0",
    "vite": ">=8.0.0",
    "vite-plugin-vue-devtools": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@intlify/unplugin-vue-i18n": {
      "optional": true
    },
    "@unhead/vue": {
      "optional": true
    },
    "unocss": {
      "optional": true
    },
    "vite-plugin-vue-devtools": {
      "optional": true
    }
  },
  "dependencies": {
    "unplugin-auto-import": "catalog:common-plugin",
    "vite-bundle-visualizer": "catalog:common-plugin",
    "vite-plugin-dynamic-base": "catalog:common-plugin",
    "@antfu/install-pkg": "catalog:prod",
    "@clack/prompts": "catalog:prod",
    "@vitejs/plugin-vue": "catalog:vue-plugin",
    "@vitejs/plugin-vue-jsx": "catalog:vue-plugin",
    "unplugin-vue-components": "catalog:vue-plugin",
    "vue-router": "catalog:vue-plugin"
  },
  "devDependencies": {
    "tsdown": "catalog:build",
    "unocss": "catalog:common-plugin",
    "bumpp": "catalog:dev",
    "nano-staged": "catalog:dev",
    "pncat": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "taze": "catalog:dev",
    "typescript": "catalog:dev",
    "deepmerge": "catalog:inlined",
    "empathic": "catalog:inlined",
    "local-pkg": "catalog:inlined",
    "pathe": "catalog:inlined",
    "pkg-types": "catalog:inlined",
    "@octohash/eslint-config": "catalog:lint",
    "eslint": "catalog:lint",
    "vitest": "catalog:test",
    "@types/node": "catalog:types",
    "@intlify/unplugin-vue-i18n": "catalog:vue-plugin",
    "vite-plugin-vue-devtools": "catalog:vue-plugin"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix"
  },
  "inlinedDependencies": {
    "acorn": "8.16.0",
    "confbox": "0.2.4",
    "deepmerge": "4.3.1",
    "empathic": "2.0.1",
    "exsolve": "1.0.8",
    "local-pkg": "1.2.1",
    "mlly": "1.8.2",
    "pathe": "2.0.3",
    "pkg-types": "2.3.1",
    "quansync": "0.2.11",
    "ufo": "1.6.4"
  }
}
