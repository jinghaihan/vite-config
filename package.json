{
  "name": "@octohash/vite-config",
  "type": "module",
  "version": "0.3.4",
  "packageManager": "pnpm@10.32.1",
  "description": "Opinionated Vite config preset.",
  "author": "jinghaihan",
  "license": "MIT",
  "homepage": "https://github.com/jinghaihan/vite-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/vite-config.git"
  },
  "bugs": {
    "url": "https://github.com/jinghaihan/vite-config/issues"
  },
  "keywords": [
    "vite",
    "vite-config"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "deps": "taze major -I",
    "catalog": "pncat",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "release": "bumpp",
    "prepare": "simple-git-hooks",
    "bootstrap": "pnpm install",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@unhead/vue": ">=2.0.0",
    "vite": ">=8.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "catalog:plugin",
    "@vitejs/plugin-vue-jsx": "catalog:plugin",
    "unplugin-auto-import": "catalog:plugin",
    "unplugin-vue-components": "catalog:plugin",
    "unplugin-vue-router": "catalog:plugin",
    "vite-bundle-visualizer": "catalog:plugin",
    "vite-plugin-dts": "catalog:plugin",
    "vite-plugin-dynamic-base": "catalog:plugin",
    "@antfu/install-pkg": "catalog:prod",
    "@clack/prompts": "catalog:prod",
    "empathic": "catalog:prod",
    "local-pkg": "catalog:prod",
    "pathe": "catalog:prod",
    "pkg-types": "catalog:prod"
  },
  "optionalDependencies": {
    "@intlify/unplugin-vue-i18n": "catalog:plugin",
    "@originjs/vite-plugin-federation": "catalog:plugin",
    "vite-plugin-jspm": "catalog:plugin",
    "vite-plugin-vue-devtools": "catalog:plugin"
  },
  "devDependencies": {
    "tsdown": "catalog:build",
    "@jspm/generator": "catalog:dev",
    "bumpp": "catalog:dev",
    "nano-staged": "catalog:dev",
    "pncat": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "taze": "catalog:dev",
    "typescript": "catalog:dev",
    "deepmerge": "catalog:inline",
    "@octohash/eslint-config": "catalog:lint",
    "eslint": "catalog:lint",
    "vitest": "catalog:test",
    "@types/node": "catalog:types"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix"
  },
  "inlinedDependencies": {
    "deepmerge": "4.3.1",
    "picomatch": [
      "2.3.1",
      "4.0.3"
    ],
    "ms": "2.1.3",
    "debug": "4.4.3",
    "has-flag": "4.0.0",
    "supports-color": "8.1.1",
    "typescript": "5.9.3",
    "eslint-visitor-keys": [
      "3.4.3",
      "5.0.1"
    ],
    "@typescript-eslint/visitor-keys": "8.57.0",
    "@typescript-eslint/types": "8.57.0",
    "@typescript-eslint/typescript-estree": "8.57.0",
    "@typescript-eslint/tsconfig-utils": "8.57.0",
    "semver": [
      "7.7.3",
      "7.7.4"
    ],
    "ts-api-utils": "2.4.0",
    "@typescript-eslint/project-service": "8.57.0",
    "fdir": "6.5.0",
    "tinyglobby": "0.2.15",
    "balanced-match": "4.0.4",
    "brace-expansion": "5.0.4",
    "minimatch": "10.2.4",
    "acorn": [
      "8.14.1",
      "8.15.0",
      "8.16.0"
    ],
    "unplugin": "2.3.11",
    "@jridgewell/sourcemap-codec": [
      "1.5.0",
      "1.5.5"
    ],
    "@jridgewell/trace-mapping": "0.3.29",
    "@jridgewell/gen-mapping": "0.3.12",
    "@jridgewell/remapping": "2.3.5",
    "webpack-virtual-modules": "0.6.2",
    "@intlify/shared": "11.1.12",
    "estraverse": "5.3.0",
    "esutils": "2.0.3",
    "source-map": "0.6.1",
    "escodegen": "2.1.0",
    "estree-walker": "2.0.2",
    "@intlify/message-compiler": "11.1.12",
    "source-map-js": "1.2.1",
    "jsonc-eslint-parser": "2.4.2",
    "espree": "9.6.1",
    "acorn-jsx": "5.3.2",
    "esbuild": "0.25.9",
    "yaml-eslint-parser": "1.3.0",
    "yaml": "2.8.2",
    "@intlify/bundle-utils": "11.0.7",
    "@rollup/pluginutils": "5.2.0",
    "fast-glob": "3.3.3",
    "is-extglob": "2.1.1",
    "is-glob": "4.0.3",
    "glob-parent": "5.1.2",
    "braces": "3.0.3",
    "is-number": "7.0.0",
    "to-regex-range": "5.0.1",
    "fill-range": "7.1.1",
    "micromatch": "4.0.8",
    "merge2": "1.4.1",
    "@nodelib/fs.stat": "2.0.5",
    "queue-microtask": "1.2.3",
    "run-parallel": "1.2.0",
    "@nodelib/fs.scandir": "2.1.5",
    "reusify": "1.1.0",
    "fastq": "1.19.1",
    "@nodelib/fs.walk": "1.2.8",
    "@vue/shared": [
      "3.5.14",
      "3.5.22"
    ],
    "entities": "4.5.0",
    "@babel/parser": "7.29.0",
    "@vue/compiler-core": [
      "3.5.14",
      "3.5.22"
    ],
    "@vue/compiler-dom": [
      "3.5.14",
      "3.5.22"
    ],
    "@vue/compiler-ssr": "3.5.14",
    "picocolors": "1.1.1",
    "postcss": "8.5.8",
    "nanoid": "3.3.11",
    "magic-string": "0.30.21",
    "lodash": "4.17.21",
    "@vue/compiler-sfc": "3.5.14",
    "vue": "3.5.14",
    "@eslint-community/eslint-utils": "4.9.1",
    "@intlify/vue-i18n-extensions": "8.0.0",
    "@typescript-eslint/scope-manager": "8.57.0",
    "@intlify/unplugin-vue-i18n": "11.0.7"
  }
}
